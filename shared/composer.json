{
  "name": "synergy-erp/shared",
  "type": "library",
  "description": "Shared models and controllers for CQRS/EDA",
  "autoload": {
    "psr-4": {
      "SynergyERP\\Shared\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SynergyERP\\Shared\\Tests\\": "src/Tests/"
    }
  },
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "barryvdh/laravel-ide-helper": "^3.1"
  }
}
